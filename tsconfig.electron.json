{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist/electron",
    "rootDir": "."
  },
  "include": ["electron/**/*", "src/core/**/*", "src/shared/**/*"],
  "exclude": ["node_modules", "dist", "src/app/**/*", "src/core/__tests__/**/*"]
}
