# Database
DATABASE_URL=postgresql://keel:keel@localhost:5432/keel

# JWT — generate with: openssl rand -base64 32
JWT_SECRET=change-this-to-a-random-secret

# S3 (MinIO for local dev, Tigris/R2/S3 in prod)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=keel-files

# Server
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# CORS — comma-separate multiple origins
# In production: https://your-app.fly.dev,capacitor://localhost,http://localhost
CORS_ORIGIN=http://localhost:5173

# Auto-migrate on startup (always true in production)
AUTO_MIGRATE=false

# Fly.io Postgres (set automatically by `fly pg attach`)
# DATABASE_URL=postgres://keel:xxx@keel-db.flycast:5432/keel

# Fly.io Tigris S3 (set via `fly storage create`)
# AWS_ENDPOINT_URL_S3=https://fly.storage.tigris.dev
# AWS_ACCESS_KEY_ID=tid_xxx
# AWS_SECRET_ACCESS_KEY=tsec_xxx
# BUCKET_NAME=keel-files
